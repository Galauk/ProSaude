				$queryVerificaGestante = pg_query($sqlVerificaGestante);
				if($usu_sexo == "F"){
					if(pg_num_rows($queryVerificaGestante) == 0){
						$stmt = "INSERT INTO usuario_gestante ( 
											 usu_codigo, 
											 gest_quantidade_parto_vaginal, 
											 gest_quantidade_cesaria, 
											 gest_quantidade_abortos, 
											 gest_quantidade_filhos_vivos, 
											 gest_quantidade_rn_2500, 
											 gest_quantidade_rn_4000, 
											 gest_tabagismo, 
											 gest_numero_cigarros_dia, 
											 gest_estatura) 
									VALUES ( 
											 '$usu_codigo', 
											 ".($gest_quantidade_parto_vaginal == "" ? "null" : $gest_quantidade_parto_vaginal).", 
											 ".($gest_quantidade_cesaria == "" ? "null" : $gest_quantidade_cesaria).",
											 ".($gest_quantidade_abortos == "" ? "null" : $gest_quantidade_abortos).",
											 ".($gest_quantidade_filhos_vivos == "" ? "null" : $gest_quantidade_filhos_vivos).",
											 ".($gest_quantidade_rn_2500 == "" ? "null" : $gest_quantidade_rn_2500).",
											 ".($gest_quantidade_rn_4000 == "" ? "null" : $gest_quantidade_rn_4000).",
											 ".($gest_tabagismo == "" ? "null" : "'$gest_tabagismo'").",
											 ".($gest_numero_cigarros_dia == "" ? "null" : $gest_numero_cigarros_dia).",
											 ".($gest_estatura == "" ? "null" : $gest_estatura).")"."";
					}else{
						$stmt = "UPDATE usuario_gestante 
									SET gest_quantidade_parto_vaginal = ".($gest_quantidade_parto_vaginal == "" ? "null" : $gest_quantidade_parto_vaginal).", 
										gest_quantidade_cesaria =  ".($gest_quantidade_cesaria == "" ? "null" : $gest_quantidade_cesaria).", 
										gest_quantidade_abortos = ".($gest_quantidade_abortos == "" ? "null" : $gest_quantidade_abortos).",
										gest_quantidade_filhos_vivos = ".($gest_quantidade_filhos_vivos == "" ? "null" : $gest_quantidade_filhos_vivos).",
										gest_quantidade_rn_2500 = ".($gest_quantidade_rn_2500 == "" ? "null" : $gest_quantidade_rn_2500).",
										gest_quantidade_rn_4000 = ".($gest_quantidade_rn_4000 == "" ? "null" : $gest_quantidade_rn_4000).", 
										gest_tabagismo = ".($gest_tabagismo == "" ? "null" : "'$gest_tabagismo'").", 
										gest_numero_cigarros_dia =  ".($gest_numero_cigarros_dia == "" ? "null" : $gest_numero_cigarros_dia).", 
										gest_estatura = ".($gest_estatura == "" ? "null" : $gest_estatura)."
										WHERE usu_codigo = $usu_codigo";
					}
					
					$queryGestante = pg_query($stmt);
				}else{
					echo $common->modalMsg("ERRO","N&atilde;o foi possivel salvar dados de gestante pois o paciente � do sexo femininol, os demais dados ser&atilde;o salvos !","paciente.php?");
					exit;
				}				
			}
			
			if ($executa){
				echo "<script>
						window.opener.retornaPac('$usu_codigo','".strtoupper($usu_nome)."');
						window.close();
					</script>";
				echo $common->modalMsg("OK", "Usu&aacute;rio salvo com sucesso!", "paciente.php?id_login=$id_login");
				//echo "Usu�rio salvo com sucesso!";
			}
			break;
		case "del":
			echo $common->modalConfirm("Deseja realmente apagar o paciente selecionado?", "paciente.php?id_login=$id_login&acao=deletar&usu_codigo=$usu_codigo", "paciente.php?id_login=$id_login&acao=&usu_codigo=$usu_codigo");
			break;
		case "deletar":
			$sqlConfiguracao = "select * from config where conf_chave = 'CADASTRO_AISE'";
			$queryConfiguracao = pg_query($sqlConfiguracao);
			$regConfiguracao = pg_fetch_array($queryConfiguracao);
			
			if($regConfiguracao['conf_valor_bool'] == "f"){
				$delete = "UPDATE usuario
						  SET usu_ativacao = 'N',
						  	  usu_dt_ativacao_desativacao = CURRENT_DATE 
						WHERE usu_codigo = ".intval($usu_codigo);
			}else{
				
				$selectPessoa = "SELECT pessoa FROM pessoa_paciente WHERE pep_codigo = ".intval($usu_codigo);
				$queryPessoa = pg_query($selectPessoa);
				$regPessoa = pg_fetch_array($queryPessoa);
				//die($selectPessoa);
				
				$delete = "UPDATE pessoa
						  SET inativo = 'S' 
						WHERE pessoa = $regPessoa[pessoa]";
				//die($delete);
			}
			
			
			
			$execDel = pg_query($delete) or die($delete);
			if ($execDel){
				echo $common->modalMsg("OK", "Paciente desativado com sucesso", "paciente.php?id_login=$id_login&acao=&usu_codigo=$usu_codigo");
			}else{
				echo $common->modalMsg("ERRO", "Houve um erro durante a desativa&ccedil;&atilde;o do paciente, tente novamente.", "paciente.php?id_login=$id_login&acao=&usu_codigo=$usu_codigo");
			}
			break;
	}
	  echo "<div id='sys'></div>";
?>