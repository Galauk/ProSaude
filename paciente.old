<script>

	jQuery(function(){
		jQuery("a.modal").click(function(e){
			var title = jQuery(this).attr("title");
			if(!title)
				title = document.title;
			
			var rel = jQuery(this).attr("rel").split("x");
			var url = jQuery(this).attr("href");
			e.preventDefault();
			e.stopPropagation();
			jQuery("#sys").append("<div id=\"modal-dialog\" title=\""+title+"\"></div>");
			jQuery("#modal-dialog")
			.load(url)
			.dialog({
				modal: true,
				width: rel[0],
				height: rel[1],
				close: function(){ return jQuery(this).remove();},
				buttons:{
					Fechar: function(){
						fecharModal();
						return false;
					}
				}
			});
		});

		jQuery("#buscar").buscar({
			tipo:'domicilio',
			
		template : function(ul, item) {
				return jQuery("<li></li>").data("item.autocomplete", item).append(
						"<a><strong>" + item.label + "</strong>"
								+ "<br><strong>Numero.:</strong> "
								+ item.data.dom_numero
								+ "<br><strong>CEP:</strong> " + item.data.rua_cep
								+ "<br><strong>Bairro:</strong>" + item.data.rua_bairro
								+ "</a>&nbsp;").appendTo(ul);
			}
			

		});

		jQuery("#buscarCid").buscar({
			tipo:'cd10',
			callback: function(event,ui){
				jQuery("#parte2").show("");
				
			}
		});
		
		jQuery("#tabs").tabs();
	});

  function fecharModal(){
		jQuery(".ui-icon-closethick").click();
  }
	
     </script>

