    public function varreServidorArqs(){
        $path = "arqs/";
        $diretorio = dir($path);
        while ($arquivo = $diretorio->read()) {
            if ($arquivo != ".svn" && date('d-m-Y', strtotime("-90 days")) < date("d-m-Y", fileatime($arquivo)) && $arquivo != "." && $arquivo != "..") {
                unlink($arquivo);
            }
        }
        $diretorio->close();
    }
