//DESCOBRE OS PROCEDIMENTO DO AGENDAMENTO NAQUELA RECEP��O
$sqlProcedimento = "SELECT med_nome, 
					i.proc_codigo,
					proc_nome,
					c.med_codigo medico,
					a.usu_codigo,
					u.usu_nome,
					ai.agei_data,
					ai.agei_status,
					a.age_codigo,
					a.med_codigo,
					a.usr_codigo_medico,
					ai.agei_codigo,
					i.coni_codigo
				  FROM medico m 
				  JOIN convenio c
				    ON c.med_codigo = m.med_codigo
				  JOIN convenio_itens i
				    ON i.conv_codigo = c.conv_codigo
				 left JOIN agenda_itens ai
				    ON ai.coni_codigo = i.coni_codigo
				  JOIN agenda a
				    ON a.age_codigo = ai.age_codigo
				  JOIN usuario u
				    ON u.usu_codigo = a.usu_codigo
				  JOIN procedimento proc
				    ON proc.proc_codigo = i.proc_codigo
				   AND agei_data = '$age_data' 
			       AND a.age_codigo = $age_codigo
				 GROUP BY med_nome,
					   c.med_codigo,
					   a.usu_codigo,
					   u.usu_nome,
					   agei_data,
					   ai.agei_status,
					   a.age_codigo,
					   a.med_codigo,
					a.usr_codigo_medico,
					i.proc_codigo,
					proc_nome,
					ai.agei_codigo,
					i.coni_codigo
				ORDER BY proc_nome";
//echo "<pre>".print_r($sqlProcedimento,1);
$queryProcedimento = pg_query($sqlProcedimento);
$queryProcedimento2 = pg_query($sqlProcedimento);

