function excluirExame(agei_codigo,id_login,age_data,med_codigo,age_codigo,usr_codigo_medico){
	decisao = confirm("Deseja realmente excluir este exame?");
	if (decisao){
		jQuery.ajax({
			url: "exclui_exame.php",
			type:"POST",
			data: {
				agei_codigo: agei_codigo
			},
			success:function(r){
				window.location.href = "exa_coleta.php?id_login="+id_login+"&age_data="+age_data+"&med_codigo="+med_codigo+"&age_codigo="+age_codigo+"&usr_codigo_medico="+usr_codigo_medico+"";
			}
		});
	} else {
		//alert ("Voc� clicou no bot�o CANCELAR,\n"+"porque foi retornado o valor: "+decisao);
	}
}

function coleta(to,id,esp_codigo){
	//alert(to+"-"+id);
        
        if (!esp_codigo){
            esp_codigo = jQuery("#esp_codigo_v").val();
        }
        
	jQuery("#coleta"+id)
		.attr("src","<?=LINKCOMUM?>/imgs/loading.gif")
		.attr("alt","Carregando...")
		.removeAttr("onclick");
	jQuery.ajax({
		url: "coleta.ajax.php",
		type:"POST",
		data: {
			agei_codigo: id,
			esp_codigo:esp_codigo,
			tipo: 'coleta',
			
			to: to
		},
		success:function(r){
			if(r == 1){
				to = 0;
				img = "selecionar";
				alt = "Sim";
			} else {
				to = 1;
				img = "excluir";
				alt = "N�o";
			}
			jQuery("#coleta"+id)
				.attr("src","<?=LINKCOMUM?>/imgsBotoes/"+img+".png")
				.attr("alt",alt)
				.attr("onclick","")
				.unbind("click")
				.stop()
				.click(function(){
					coleta(to,id);	
				});

			if(r==1){			
				jQuery("#data_previsao"+id)
					.stop()
					.bind('keypress',function(event){
						Ajusta_Data(this, event)
						})
					.show('fast');
				_i++;

				//if(_i==2) jQuery("body").hide(5000);
			}else{
				jQuery("#data_previsao"+id)
				.stop()
				.hide('normal');
			}
		}
	});
}

function addExames(age_codigo){
	var html = "<input type=hidden name=coni_codigo id=coni_codigo value=''>";
	html += "<input type=text name=proc_nome id=proc_nome value='' placeholder='Procedimento' class='inputForm' style='width:250px;'>";
	
	jQuery("#modal")
	.html(html)
	.dialog({
		modal: true,
		width: 520,
		height: 300,
		close: function(){
			jQuery("#modal").dialog('close');
		},
		buttons: {
			Ok: function(){
				salvaProcedimentos(age_codigo);				
				//jQuery(this).dialog('close');
			}
		}
	});
	
	jQuery("#proc_nome").buscar({
	   tipo:'procedimento_convenio',
	   parametro:jQuery("#lab_codigo").val(),
	   template : function(ul, item) {
					return jQuery("<li></li>").data("item.autocomplete", item).append(
							"<a>" + item.label + "</a>").appendTo(ul);
			}
	});

}

function salvaProcedimentos(age_codigo){
	if(jQuery("#coni_codigo").val() == null)
		return false;

	jQuery(".proced").each(function(){
		//alert(jQuery(this).val() +"== "+ jQuery("#coni_codigo").val());
		if(jQuery(this).val() == jQuery("#coni_codigo").val()){
			alert("Este procedimento ja foi inserido!");
			jQuery("#modal").dialog('close');
			jQuery("#modal1").html("<div id='modal' style='display:none;' title='Adicionar Procedimento'> </div>");
			return false;
		}
	});
	 
	jQuery.ajax({
		url: "inserir_novo_exame.php",
		data:{age_codigo:age_codigo,
		coni_codigo:jQuery("#coni_codigo").val(),
		proc_nome: jQuery("#proc_nome").val(),
		id_login : jQuery("#id_login").val(),
		age_data : jQuery("#age_data").val()},
	    success: function(txt){
			//alert(txt[0].age_codigo+"a");
			resultObj = jQuery.parseJSON(txt);;
                       
			if (txt == 2){
				alert("Erro ao salvar procedimento!");
				
			}else{
                            //alert(jQuery("#esp_codigo_v").val());
                            if(jQuery("#permissao").val() == "0"){
                                var tr = "<tr>"+
							"<td>"+
								resultObj.proc_nome+
							"</td>"+
							"<td>"+
								"<input type='text' id='data_previsao"+resultObj.agei_codigo+"' name='data_previsao["+resultObj.agei_codigo+"]' value='' size=''   maxlength='10'   class='inputForm ' onkeypress=Ajusta_Data(this, event); >"+
							"<td>"+
                                                        "</td>"+
                                                        "<td>"+
								"<img src='/WebSocialComum/imgs/excluir_on.jpg' id='coleta"+resultObj.agei_codigo+"' onclick=excluirExame('"+resultObj.agei_codigo+"',null,'"+resultObj.age_data+"','"+jQuery("#usr_codigo").val()+"','"+age_codigo+"','') alt='Clique para cancelar' title='Clique para cancelar' style='cursor:pointer'>"
							"</td>"+
						 "</tr>";
                                
                            }else{
				var tr = "<tr>"+
							"<td>"+
								resultObj.proc_nome+
							"</td>"+
							"<td>"+
								"<input type='text' id='data_previsao"+resultObj.agei_codigo+"' name='data_previsao["+resultObj.agei_codigo+"]' value='' size=''   maxlength='10'   class='inputForm ' onkeypress=Ajusta_Data(this, event); >"+
							"<td>"+
								"<img src='/WebSocialComum/imgsBotoes/excluir.png' id='coleta"+resultObj.agei_codigo+"' onclick=coleta(1,"+resultObj.agei_codigo+",'"+jQuery("#esp_codigo_v").val()+"') alt='Nao' title='Clique para alterar' style='width:16px;cursor:pointer'>"+
							"</td>"+
							"<td>"+
								"<img src='/WebSocialComum/imgs/excluir_on.jpg' id='coleta"+resultObj.agei_codigo+"' onclick=excluirExame('"+resultObj.agei_codigo+"',null,'"+resultObj.age_data+"','"+jQuery("#usr_codigo").val()+"','"+age_codigo+"','') alt='Clique para cancelar' title='Clique para cancelar' style='cursor:pointer'>"
							"</td>"+
						 "</tr>";
                            }
				 jQuery(".exames").append(tr);
				 jQuery("#modal").dialog('close');
				 jQuery("#modal1").html("<div id='modal' style='display:none;' title='Adicionar Procedimento'> </div>");
			 }
		}
		
	});
}

