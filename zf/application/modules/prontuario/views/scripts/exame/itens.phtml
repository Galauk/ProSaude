
<?php if(isset($this->itens) && $this->itens && $this->itens->count()): ?>
<div class="space"></div>

<form method="post" action="<?= $this->url(array("action" => "imprimir-selecionados")); ?>">
<input type="hidden" id="imprimir" value="<?=($this->selecionados?implode(",",$this->selecionados):"0");?>" />
