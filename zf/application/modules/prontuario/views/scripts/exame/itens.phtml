			$proc = substr($this->escape($item->proc_nome),0,15)."...";
		}else{
			$proc = $this->escape($item->proc_nome);
		}?>
				
		<tr>
			<td class="ui-state-default"><?php echo $this->formCheckbox("imprimir[]",$item->req_codigo, array('checked' => ($this->selecionados && in_array($item->req_codigo,$this->selecionados))));?></td>
			<td class="ui-state-default"><?=$proc?></td>
                        <?php if($this->obs != 'S'){?>
                          <td class="ui-state-default escape"><?=str_replace("<p>&nbsp;</p>","",$item->req_observacao);?></td>
                        <?}?>
                        
			<?php if(!$this->imprimi){ ?>	
			<td class="ui-state-default c">								
                            <a href="<?=$this->url(array("module"=>"prontuario","controller"=>"exame","action"=>"excluir","id"=>$item->req_codigo));?>" class="excluir"><img src="<?=$this->baseUrl('/public/images/icons/excluir.png');?>" alt="Excluir" title="Excluir" /></a>
					
			</td>
			<?php }?>
		</tr>
		<?php endforeach; ?>
	</table>
	<div class="space"></div>
	<?php if($this->obs == 'S'){
            
		$action = $this->url(array("modulo" => "prontuario","module" => "prontuario", "controller" => "exame", "action" => "imprimir", "obs" => "S","ate_codigo"=>$this->ate_codigo,"usu_codigo"=>$this->usu_codigo)); 

		$action2via = $this->url(array("seg"=>"1","qnt_vias"=>"2","modulo" => "prontuario","module" => "prontuario", "controller" => "exame", "action" => "imprimir", "obs" => "S","ate_codigo"=>$this->ate_codigo,"usu_codigo"=>$this->usu_codigo)); 
	}else{
		$action = $this->url(array("modulo" => "prontuario","module" => "prontuario", "controller" => "exame", "action"=>"imprimir","usu_codigo"=>$this->usu_codigo));

		$action2via = $this->url(array("seg"=>"1","qnt_vias"=>"2","modulo" => "prontuario","module" => "prontuario", "controller" => "exame", "action"=>"imprimir","usu_codigo"=>$this->usu_codigo));
	}

        ?>
	<?php if(!$this->imprimi){?>
            <a href="<?= $action;?>" class="ui-button imprimir popup" rel="630x540" data-atalho="CTRL+P">Imprimir Todos</a>
            <?php if(!$this->obs == 'S'){?>
                <a href="#" class="ui-button submit imprimir" data-atalho="CTRL+I">Imprimir Selecionados</a>
            <?php } ?>
                <a href="<?=$action2via?>" rel="630x540"  class="ui-button imprimir  popup">Imprimir<small>(Duas vias)</small></a>
	<?php } ?>
	
</form>
<?php else: ?>
<br /><em>Nenhum exame adicionado ainda.</em>
