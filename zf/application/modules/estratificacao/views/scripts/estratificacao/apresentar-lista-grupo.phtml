                        <th scope="row"><?=$contador+1?></th>
                        <td><?=$this->recebeListar[$contador][est_gruponome]?></td>
                        <td><?=$this->recebeListar[$contador][to_char]?></td>
                        <td>

                        <a href="<?=$this->url(array("action"=>"editar-grupo", "module"=>"estratificacao","controller" => "estratificacao","param" => $this->recebeListar[$contador][id_grupoperg],NULL,TRUE));?>">Editar</a>


                                
                        <a id = "linkDesativar<?=$this->recebeListar[$contador][id_grupoperg]?>">
                            
                            <?php
                                if ($this->recebeListar[$contador][grupo_ativo] == "1") { ?>

                                    <img title = "Desativar Grupo" onclick = "desativarGrupo(<?=$this->recebeListar[$contador][id_grupoperg]?>)" id = "botaoDesativar<?=$this->recebeListar[$contador][id_grupoperg]?>" src="/WebSocialSaude/zf/public/images/icons/remove.png" alt=""> 
                                <?}?>
                        </a>
                                    
                        <a id = "linkAtivar<?=$this->recebeListar[$contador][id_grupoperg]?>" >
