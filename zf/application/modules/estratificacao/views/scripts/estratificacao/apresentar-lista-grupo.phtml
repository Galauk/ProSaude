                                if ($this->recebeListar[$contador][grupo_ativo] != "1") { ?>                                        
                                        <img title = "Ativar Grupo" onclick = "ativarGrupo(<?=$this->recebeListar[$contador][id_grupoperg]?>)" id = "botaoAtivar<?=$this->recebeListar[$contador][id_grupoperg]?>" src="/WebSocialSaude/zf/public/images/icons/atualizar.png" alt="">
                                <?}?>
