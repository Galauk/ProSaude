	<queryString language="plsql">
		<![CDATA[SELECT usu.*,
                               dom.dom_codigo,
                               dom.dom_numero,
                               dom.dom_complemento,
                               dom.dom_ponto_referencia,
                               dom.dom_telefone,
                               dom.dom_as_localizacao,
                               dom.dom_as_abrigo,
                               bai.bai_codigo,
                               bai.bai_nome,
                               rua.rua_nome,
                               rua.rua_codigo,
                               rua.rua_cep,
                               cid.cid_codigo,
                               cid.cid_nome,
                               est.uf_codigo,
                               est.uf_nome,
                               est.uf_sigla
                        FROM usuario usu
                        INNER JOIN as_prontuario_suas_usuario aspsu ON usu.usu_codigo = aspsu.usu_codigo
                        INNER JOIN as_prontuario_suas asps ON aspsu.asps_codigo = asps.asps_codigo
                        LEFT JOIN domicilio dom ON dom.dom_codigo = usu.dom_codigo
                        LEFT JOIN bairro bai ON dom.bai_codigo = bai.bai_codigo
                        LEFT JOIN rua ON rua.rua_codigo = dom.rua_codigo
                        LEFT JOIN cidade cid ON cid.cid_codigo = rua.cid_codigo
                        LEFT JOIN estado est ON cid.uf_codigo = est.uf_codigo
                        WHERE usu.usu_asps_ativo ='t' AND
                              usu.usu_asps_ref ='t']]>
	</queryString>
