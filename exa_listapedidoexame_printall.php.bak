$sql = "select distinct(itx.itx_codigo),
			   proc_nome,
			   to_char(mlz_datadacoleta,'DD/MM/YYYY') as mlz_datadacoleta,
			   proc.proc_codigo,
			   mlz.cad_exame,
			   mlz_coletado
		  from materialdeanalise as mlz 
		  left join itensdoexame as itx 
		    on itx.itx_codigo = mlz.itx_codigo 
		  left join procedimento as proc 
		    on proc.proc_codigo = itx.proc_codigo 
		  left join tipodeexame as tp 
		    on tp.proc_codigo = itx.proc_codigo 
		  join resultadoexame as r 
		    on itx.itx_codigo = r.itx_codigo 
		 where mlz.cad_exame = $cad_exame";
$querySql = pg_query($sql);
	//$sql = pg_query("select *from materialdeanalise as mlz left join itensdoexame as itx on itx.itx_codigo = mlz.itx_codigo left join procedimento as proc on proc.proc_codigo = itx.proc_codigo left join tipodeexame as tp on tp.proc_codigo = itx.proc_codigo join resultadoexame as r on itx.itx_codigo = r.itx_codigo where mlz.cad_exame = $cad_exame");

