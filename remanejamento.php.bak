//-> DEL <---------------------------------------------------------->

 if($acao=="del") {
	 reglog($id_login,"Exluindo Registro de TRANSFERENCIA $mov_codigo");

  $sql = pg_query("delete from movimento where mov_codigo='$mov_codigo'");
msg($id_login,$acao,$sql);
}

